{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mesh-log-mapper",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-18",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/", "/index.html", "/api/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],

  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "mesh_logger",
      "id": "1959f3e455c643e2a86d5f48ec6fa120"
    }
  ]
}
